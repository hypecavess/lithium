# ==============================================================================
# Lithium - root .gitignore
# ==============================================================================

# ------------------------------------------------------------------------------
# Dependencies & Package Managers
# ------------------------------------------------------------------------------
node_modules/
/node_modules
*/node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ------------------------------------------------------------------------------
# Build and Compilation Outputs
# ------------------------------------------------------------------------------
# General build directories
dist/
build/
out/
/website/out
/application/dist

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Next.js
.next/
/website/.next/

# ------------------------------------------------------------------------------
# Environment Variables & Secrets (Keep .env.example, ignore all other envs)
# ------------------------------------------------------------------------------
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local
.env*
!.env.example

# ------------------------------------------------------------------------------
# Debugging & Logs
# ------------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ------------------------------------------------------------------------------
# Editor & IDE Configs
# ------------------------------------------------------------------------------
# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# IntelliJ / WebStorm / PhpStorm
.idea/

# ------------------------------------------------------------------------------
# System & OS Specific Files
# ------------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini

# ------------------------------------------------------------------------------
# Deployments & Hosting
# ------------------------------------------------------------------------------
.vercel
.serverless/

.vercel
